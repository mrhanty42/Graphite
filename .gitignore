/graphite-host/src/main/resources/natives/linux/*.so
/graphite-host/src/main/resources/natives/macos/*.dylib
/graphite-host/src/main/resources/natives/macos-arm64/*.dylib

# Local test mods copied into run directories
/graphite-host/**/graphite_mods/*.dll
/graphite-host/**/graphite_mods/*.so
/graphite-host/**/graphite_mods/*.dylib
